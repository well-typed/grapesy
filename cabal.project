  tag: 5610f8d67c1fb5e5bec951cca1b3e810b03fc922
  subdir: time-manager

-- TODO: Temporary
-- <https://github.com/google/ghc-source-gen/issues/109#issuecomment-2517622160>
constraints: any.ghc-source-gen==0.4.5.0

