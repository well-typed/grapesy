packages:
    ./grpc-spec
  , ./grapesy
  , ./tutorials/quickstart
  , ./tutorials/basics
  , ./tutorials/lowlevel
  , ./tutorials/metadata
  , ./tutorials/monadstack
  , ./tutorials/conduit
  , ./tutorials/trailers-only

packages: garp

tests: True
benchmarks: True

package grpc-spec
  flags: +snappy

package grapesy
  flags: +build-demo +build-stress-test

-- avoid compilation errors in some dependencies
if impl(ghc < 9.4)
  constraints: diagrams-lib==1.4.6.2
